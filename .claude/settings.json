{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus[1m]",
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "other",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Exiting Claude'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__playwright__.*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mikemarion/.claude/hooks/playwright-localhost-gate.py"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "awaySummaryEnabled": false,
  "editorMode": "vim",
  "useAutoModeDuringPlan": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754345828361
  }
}
